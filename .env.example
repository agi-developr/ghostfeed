# Video generation
NEBIUS_API_KEY=your_nebius_api_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...   # $49/mo
STRIPE_PRICE_PRO=price_...       # $99/mo
STRIPE_PRICE_AGENCY=price_...    # $299/mo

# TikTok OAuth app (register at developers.tiktok.com)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google OAuth app (console.cloud.google.com → YouTube Data API v3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Direct token override (optional, for CLI use without OAuth)
TIKTOK_ACCESS_TOKEN=
YOUTUBE_ACCESS_TOKEN=

# App
NEXT_PUBLIC_BASE_URL=https://ghostfeed.app
